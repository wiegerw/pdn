# Generated ANTLR4 parser files (regenerated by pip install -e .)
python/pdn_antlr/*.py
python/pdn_antlr/*.tokens
python/pdn_antlr/*.interp
# Keep the package stub so setuptools can discover the package
!python/pdn_antlr/__init__.py

# Python build artifacts
python/__pycache__/
python/*.egg-info/
python/.eggs/
__pycache__/
*.pyc
